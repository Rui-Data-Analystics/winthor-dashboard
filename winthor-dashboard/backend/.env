# Porta em que o backend vai rodar
PORT=3001

# Dados de conexao do Banco de Dados Oracle (WinThor)
# Altere estes valores conforme os dados do seu servidor de banco de dados
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_CONNECTION_STRING=localhost:1521/XE

# Exemplo de string de conexao:
# Se o seu banco esta no IP 192.168.1.100 na porta 1521 com o SID 'prod':
# DB_CONNECTION_STRING=192.168.1.100:1521/prod
